<UserControl x:Class="ql_ks.Views.UC_TraCuuPhong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ql_ks.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <Grid Margin="20" Background="#F3F5FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,16">
            <TextBlock Text="PHẦN MỀM QUẢN LÍ KHÁCH SẠN" FontSize="26" FontWeight="Bold" Foreground="#30324A"/>
            <TextBlock Text="TRA CỨU / QUẢN LÝ PHÒNG" FontSize="16" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- TRÁI: TÌM KIẾM + FORM THÔNG TIN (CÓ THANH KÉO) -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False">
                    <StackPanel>
                        <!-- Tìm kiếm -->
                        <TextBlock Text="🔍 Tìm kiếm" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Padding="10,0" VerticalContentAlignment="Center"
                                 BorderBrush="#CBD5E1" BorderThickness="1"/>

                        <Button Content="🔍 Tìm kiếm" Command="{Binding TimKiemCommand}" 
                                Background="#3498DB" Foreground="White" Height="36" Margin="0,10,0,0" 
                                BorderThickness="0" FontWeight="Bold"/>
                        <Button Content="✖ Làm mới" Command="{Binding LamMoiCommand}" 
                                Background="#95A5A6" Foreground="White" Height="36" Margin="0,8,0,0" 
                                BorderThickness="0"/>

                        <!-- Form Thông tin phòng -->
                        <Border Background="#F1F5F9" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" 
                                Padding="12" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="➕ Thông tin phòng" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>

                                <TextBlock Text="Mã phòng *" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SelectedPhong.Ma_Phong, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#94A3B8"/>

                                <TextBlock Text="Loại phòng" FontSize="11" Foreground="#64748B" Margin="0,8,0,4"/>
                                <ComboBox ItemsSource="{Binding DanhSachLoaiPhong}"
                                          SelectedValue="{Binding SelectedPhong.Ma_LP}"
                                          DisplayMemberPath="Ten_LP"
                                          SelectedValuePath="Ma_LP"
                                          Height="32" BorderBrush="#94A3B8"/>

                                <TextBlock Text="Tình trạng phòng" FontSize="11" Foreground="#64748B" Margin="0,8,0,4"/>
                                <ComboBox ItemsSource="{Binding TinhTrangList}"
                                          SelectedItem="{Binding SelectedPhong.TinhTrang_Phong}"
                                          Height="32" BorderBrush="#94A3B8"/>
                            </StackPanel>
                        </Border>

                        <Button Content="💾 LƯU PHÒNG" Command="{Binding LuuCommand}" 
                                Background="#F59E0B" Foreground="White" Height="38" Margin="0,12,0,0" 
                                BorderThickness="0" FontWeight="Bold" FontSize="14" Cursor="Hand"/>

                        <TextBlock Text="{Binding ThongBao}" Foreground="Red" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- PHẢI: DATA GRID -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
                <DockPanel>
                    <!-- Toolbar -->
                    <ToolBarTray DockPanel.Dock="Top" Background="WhiteSmoke" Margin="0,0,0,10">
                        <ToolBar>
                            <Button Content="➕ Thêm mới" Command="{Binding ThemCommand}" 
                                    Background="#27AE60" Foreground="White" Padding="8,5" BorderThickness="0" Margin="0,0,5,0"/>
                            <Button Content="💾 Lưu" Command="{Binding LuuCommand}" 
                                    Background="#F59E0B" Foreground="White" Padding="8,5" BorderThickness="0" Margin="0,0,5,0"/>
                            <Button Content="✏️ Sửa" Command="{Binding SuaCommand}" 
                                    Background="#2980B9" Foreground="White" Padding="8,5" BorderThickness="0" Margin="0,0,5,0"/>
                            <Button Content="❌ Xóa" Command="{Binding XoaCommand}" 
                                    Background="#E74C3C" Foreground="White" Padding="8,5" BorderThickness="0"/>
                            <Separator/>
                            <Button Content="📊 Xuất báo cáo" Background="#95A5A6" Foreground="White" Padding="8,5" BorderThickness="0"/>
                        </ToolBar>
                    </ToolBarTray>

                    <DataGrid ItemsSource="{Binding DanhSachHienThi}" 
                              SelectedItem="{Binding SelectedPhong, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="40"
                              SelectionMode="Single"
                              BorderThickness="0"
                              Background="White">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã phòng" Binding="{Binding Ma_Phong}" Width="90" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Loại phòng" Binding="{Binding TenLoaiPhong}" Width="*" MinWidth="140"/>
                            <DataGridTextColumn Header="Tình trạng" Binding="{Binding TinhTrang_Phong}" Width="120"/>
                            <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat={}{0:N0}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- StatusBar -->
                    <StatusBar DockPanel.Dock="Bottom" Background="#F1F5F9" Margin="-16,10,-16,-16" Padding="10,5">
                        <StatusBarItem Content="{Binding ThongBao}" HorizontalAlignment="Right"/>
                    </StatusBar>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>