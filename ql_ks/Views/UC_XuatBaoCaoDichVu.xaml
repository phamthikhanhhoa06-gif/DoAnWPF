<UserControl x:Class="ql_ks.Views.UC_XuatBaoCaoDichVu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#F5F7FA">

    <!-- ✅ THÊM RESOURCE Ở ĐÂY -->
    <UserControl.Resources>
        <Style x:Key="CenterAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RightAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Grid.Row="0" Text="BÁO CÁO DOANH THU DỊCH VỤ" 
                   FontSize="20" FontWeight="Bold" Foreground="#2C3E50" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#E5E7EB" 
                BorderThickness="1" Padding="8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="🖨️ In" Click="BtnIn_Click"
                        Background="#3498DB" Foreground="White" Padding="12,6" 
                        BorderThickness="0" FontWeight="Bold" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="🔄 Làm mới" Click="BtnLamMoi_Click"
                        Background="#27AE60" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="💾 Lưu file" Click="BtnLuuFile_Click"
                        Background="#F39C12" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="📋 Copy" Click="BtnCopy_Click"
                        Background="#9B59B6" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="🔍 Zoom" Click="BtnZoom_Click"
                        Background="#1ABC9C" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Separator Background="#CCC" Width="1" Margin="5,2"/>
                <Button Content="◀ Trước" Click="BtnTrangTruoc_Click"
                        Background="#95A5A6" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="Sau ▶" Click="BtnTrangSau_Click"
                        Background="#95A5A6" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Cursor="Hand"/>
                <TextBlock x:Name="txtTrangHienTai" Text="Trang 1/1" 
                           VerticalAlignment="Center" Margin="15,0,0,0" 
                           Foreground="#555" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- NỘI DUNG BÁO CÁO -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" 
                BorderBrush="#E5E7EB" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="reportContent" Width="750" Margin="40,30">

                    <TextBlock Text="BÁO CÁO DOANH THU DỊCH VỤ" FontSize="20" 
                               FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtNgayLap" Text="" FontSize="12" 
                               Foreground="#888" HorizontalAlignment="Center" Margin="0,5,0,25"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Thời gian lập:" 
                                   FontWeight="Bold" Foreground="#555" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtThoiGianLap" 
                                   Foreground="#333" Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Khoảng thời gian:" 
                                   FontWeight="Bold" Foreground="#555" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtKhoangThoiGian" 
                                   Foreground="#333"/>
                    </Grid>

                    <Separator Background="#E5E7EB" Margin="0,0,0,15"/>

                    <TextBlock Text="BẢNG CHI TIẾT DOANH THU" FontSize="15" 
                               FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgChiTiet" AutoGenerateColumns="False" 
                              CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="All"
                              BorderBrush="#DDD" BorderThickness="1" RowHeight="38"
                              AlternatingRowBackground="#F8F9FA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Width="60" 
                                                Binding="{Binding STT}" 
                                                ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Loại dịch vụ" Width="*" 
                                                Binding="{Binding TenDichVu}"/>
                            <DataGridTextColumn Header="Doanh thu (VNĐ)" Width="160" 
                                                Binding="{Binding DoanhThu, StringFormat={}{0:N0}}"
                                                ElementStyle="{StaticResource RightAlignStyle}"/>
                            <DataGridTextColumn Header="Tỷ lệ (%)" Width="100" 
                                                Binding="{Binding TyLe, StringFormat={}{0:P2}}"
                                                ElementStyle="{StaticResource CenterAlignStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#EBF5FB" CornerRadius="4" Margin="0,10,0,25" Padding="10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="TỔNG CỘNG: " FontSize="15" FontWeight="Bold" 
                                       Foreground="#2C3E50" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtTongCong" Text="0 VNĐ" FontSize="15" 
                                       FontWeight="Bold" Foreground="#E74C3C" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="BIỂU ĐỒ TỶ LỆ DOANH THU THEO DỊCH VỤ" FontSize="15" 
                               FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"
                               HorizontalAlignment="Center"/>

                    <Grid Height="320" Margin="0,0,0,15">
                        <Canvas x:Name="canvasBieuDo" HorizontalAlignment="Left" 
                                Width="350" Height="300"/>
                        <ItemsControl x:Name="lstLegend" HorizontalAlignment="Right" 
                                      VerticalAlignment="Center" Margin="0,0,30,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <Border Width="16" Height="16" CornerRadius="3" 
                                                Background="{Binding Color}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Label}" FontSize="13" 
                                                   Foreground="#555"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Grid Margin="0,20,0,0">
                        <TextBlock Text="Người lập báo cáo" HorizontalAlignment="Left" 
                                   FontStyle="Italic" Foreground="#888"/>
                        <TextBlock Text="Trưởng phòng" HorizontalAlignment="Right" 
                                   FontStyle="Italic" Foreground="#888"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>