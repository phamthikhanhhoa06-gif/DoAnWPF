<UserControl x:Class="ql_ks.Views.UC_XuatBaoCaoThang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ql_ks.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             Background="#F5F7FA">

    <UserControl.Resources>
        <Style x:Key="CenterAlign" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RightAlign" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Grid.Row="0" Text="BÁO CÁO DOANH THU THÁNG" 
                   FontSize="20" FontWeight="Bold" Foreground="#2C3E50" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#E5E7EB" 
                BorderThickness="1" Padding="8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="🖨️ In" Click="BtnIn_Click"
                        Background="#3498DB" Foreground="White" Padding="12,6" 
                        BorderThickness="0" FontWeight="Bold" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="🔄 Làm mới" Click="BtnLamMoi_Click"
                        Background="#27AE60" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="💾 Lưu file" Click="BtnLuuFile_Click"
                        Background="#F39C12" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="📋 Copy" Click="BtnCopy_Click"
                        Background="#9B59B6" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="🔍 Zoom" Click="BtnZoom_Click"
                        Background="#1ABC9C" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Separator Background="#CCC" Width="1" Margin="5,2"/>
                <Button Content="◀ Trước" Click="BtnTrangTruoc_Click"
                        Background="#95A5A6" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                <Button Content="Sau ▶" Click="BtnTrangSau_Click"
                        Background="#95A5A6" Foreground="White" Padding="12,6" 
                        BorderThickness="0" Cursor="Hand"/>
                <TextBlock x:Name="txtTrangHienTai" Text="Trang 1/1" 
                           VerticalAlignment="Center" Margin="15,0,0,0" 
                           Foreground="#555" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- NỘI DUNG BÁO CÁO -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" 
                BorderBrush="#E5E7EB" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="reportContent" Width="750" Margin="40,30">

                    <!-- TIÊU ĐỀ -->
                    <TextBlock Text="BÁO CÁO DOANH THU THÁNG" FontSize="18" 
                               FontWeight="Bold" Foreground="#2C3E50" 
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtNgayLap" Text="" FontSize="12" 
                               Foreground="#888" HorizontalAlignment="Center" Margin="0,5,0,20"/>

                    <!-- THÔNG TIN BÁO CÁO -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ngày lập:" 
                                   FontWeight="Bold" Foreground="#555" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtNgayLapInfo" 
                                   Foreground="#333" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Năm báo cáo:" 
                                   FontWeight="Bold" Foreground="#555" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtNamBC" 
                                   Foreground="#333" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tháng báo cáo:" 
                                   FontWeight="Bold" Foreground="#555" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtThangBC" 
                                   Foreground="#333" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Người lập:" 
                                   FontWeight="Bold" Foreground="#555" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="NguoiLap" 
                                   Text="Võ Ngọc Phong" Foreground="#333"/>
                    </Grid>

                    <Separator Background="#E5E7EB" Margin="0,0,0,15"/>

                    <!-- BẢNG CHI TIẾT -->
                    <TextBlock Text="CHI TIẾT DOANH THU THEO NGÀY" FontSize="14" 
                               FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgChiTiet" AutoGenerateColumns="False" 
                              CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="All"
                              BorderBrush="#DDD" BorderThickness="1" RowHeight="33"
                              AlternatingRowBackground="#F8F9FA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Width="60" 
                                                Binding="{Binding STT}" 
                                                ElementStyle="{StaticResource CenterAlign}"/>
                            <DataGridTextColumn Header="Ngày" Width="*" 
                                                Binding="{Binding Ngay}"/>
                            <DataGridTextColumn Header="Doanh thu (VNĐ)" Width="160" 
                                                Binding="{Binding DoanhThu, StringFormat={}{0:N0}}"
                                                ElementStyle="{StaticResource RightAlign}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- TỔNG CỘNG -->
                    <Border Background="#EBF5FB" CornerRadius="4" Margin="0,10,0,25" Padding="10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="TỔNG CỘNG: " FontSize="14" FontWeight="Bold" 
                                       Foreground="#2C3E50" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtTongCong" Text="0 VNĐ" FontSize="14" 
                                       FontWeight="Bold" Foreground="#E74C3C" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- CHỮ KÝ -->
                    <Grid Margin="0,20,0,0">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="Người lập báo cáo" FontStyle="Italic" 
                                       Foreground="#888" Margin="0,0,0,30"/>
                            <!--<TextBlock Text="Võ Ngọc Phong" FontWeight="Bold" Foreground="#333"/>-->
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right">
                            <TextBlock Text="Trưởng phòng" FontStyle="Italic" 
                                       Foreground="#888" Margin="0,0,0,30"/>
                            <TextBlock Text="________________" Foreground="#333"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
