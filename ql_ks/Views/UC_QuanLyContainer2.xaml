<UserControl x:Class="ql_ks.Views.UC_QuanLyContainer2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ql_ks.Views"
             mc:Ignorable="d" 
               d:DesignHeight="750" d:DesignWidth="1200"
             Background="#F5F7FA">

    <UserControl.Resources>
        <!-- Style cho nút Tab -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#3498DB"/>
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style cho nút Tab đang active -->
        <Style x:Key="ActiveTabStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#2C3E50"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnBaoCaoDV" Content="Báo cáo dịch vụ" Style="{StaticResource ActiveTabStyle}" Click="BtnBaoCaoDV_Click"/>
                <Button x:Name="btnBaoCaoThang" Content="Báo cáo tháng" Style="{StaticResource TabButtonStyle}" Click="BtnBaoCaoThang_Click"/>
                <Button x:Name="btnBaoCaoNam" Content="Báo cáo năm" Style="{StaticResource TabButtonStyle}" Click="BtnBaoCaoNam_Click"/>
                <Button x:Name="btnBaoCaoKH" Content="Báo cáo khách hàng" Style="{StaticResource TabButtonStyle}" Click="BtnBaoCaoKH_Click"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl x:Name="ContentArea" Grid.Row="1" Margin="0"/>
    </Grid>
</UserControl>
