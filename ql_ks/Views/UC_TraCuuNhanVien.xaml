<UserControl x:Class="ql_ks.Views.UC_TraCuuNhanVien"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ql_ks.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <Grid Margin="20" Background="#F3F5FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,16">
            <TextBlock Text="PHẦN MỀM QUẢN LÍ KHÁCH SẠN" FontSize="26" FontWeight="Bold" Foreground="#30324A"/>
            <TextBlock Text="TRA CỨU / QUẢN LÝ NHÂN VIÊN" FontSize="16" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- TRÁI: FILTER PANEL -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
                <StackPanel>
                    <!-- O. Nhân viên (STT 1) -->
                    <TextBlock Text="O. Nhân viên" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,10"/>
                    <TextBox Name="txtSearch"
                             Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"
                             Height="36"
                             Padding="12,0"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"/>

                    <!-- O. Ngày bắt đầu -->
                    <TextBlock Text="O. Ngày bắt đầu" FontWeight="Bold" Foreground="#374151" Margin="0,18,0,8"/>
                    <DatePicker SelectedDate="{Binding NgayBatDau}" Height="34" Padding="12,0" BorderBrush="#CBD5E1"/>

                    <!-- O. Ngày kết thúc -->
                    <TextBlock Text="O. Ngày kết thúc" FontWeight="Bold" Foreground="#374151" Margin="0,14,0,8"/>
                    <DatePicker SelectedDate="{Binding NgayKetThuc}" Height="34" Padding="12,0" BorderBrush="#CBD5E1"/>

                    <!-- O. Lọc -->
                    <TextBlock Text="O. Lọc" FontWeight="Bold" Foreground="#374151" Margin="0,20,0,8"/>
                    <ComboBox ItemsSource="{Binding LocChucVuList}"
                              SelectedValue="{Binding LocChucVu}"
                              Height="34"
                              Padding="12,0"
                              BorderBrush="#CBD5E1"/>

                    <!-- Lưu ý cho Lọc -->
                    <TextBlock Text="(STT 2) Chọn loại để lọc theo chức vụ: Quản lý, Lễ tân..." 
                               Foreground="#9CA3AF" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>

                    <!-- Button -->
                    <Button Content="🔍 Tìm kiếm" Command="{Binding TimKiemCommand}" 
                            Background="#3498DB" Foreground="White" Height="36" Margin="0,20,0,0" BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand"/>

                    <Button Content="✖ Làm mới" Command="{Binding LamMoiCommand}" 
                            Background="#95A5A6" Foreground="White" Height="36" Margin="0,8,0,0" BorderThickness="0" FontSize="14" Cursor="Hand"/>

                    <!-- Thông báo -->
                    <TextBlock Text="{Binding ThongBao}" Foreground="Red" FontSize="13" Margin="0,16,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- PHẢI: DATA GRID + ACTIONS -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
                <DockPanel>
                    <!-- Thanh công cụ DataGrid - SỬA: Thêm ToolBar -->
                    <ToolBarTray DockPanel.Dock="Top" Background="WhiteSmoke" Margin="0,0,0,10">
                        <ToolBar>
                            <Button Content="➕ Thêm mới" Command="{Binding ThemCommand}" ToolTip="Thêm nhân viên mới" Background="#27AE60" Foreground="White" Padding="8,5" BorderThickness="0"/>
                            <Button Content="✏️ Sửa" Command="{Binding SuaCommand}" ToolTip="Sửa nhân viên được chọn" Background="#2980B9" Foreground="White" Padding="8,5" BorderThickness="0"/>
                            <Button Content="❌ Xóa" Command="{Binding XoaCommand}" ToolTip="Xóa nhân viên được chọn" Background="#E74C3C" Foreground="White" Padding="8,5" BorderThickness="0"/>
                            <Separator/>
                            <Button Content="📊 Xuất báo cáo" ToolTip="Xuất Excel/PDF báo cáo thống kê" Background="#95A5A6" Foreground="White" Padding="8,5" BorderThickness="0"/>
                        </ToolBar>
                    </ToolBarTray>

                    <DataGrid ItemsSource="{Binding DanhSachHienThi}" 
                              SelectedItem="{Binding SelectedNhanVien, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="36"
                              SelectionMode="Single"
                              BorderThickness="0"
                              Background="White">

                        <DataGrid.Columns>
                            <!-- Checkbox cột đầu tiên - SỬA: Bỏ ElementStyle rối rắm -->
                            <DataGridCheckBoxColumn Header="" Width="40" Binding="{Binding IsChecked, Mode=TwoWay}">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>

                            <DataGridTextColumn Header="Mã NV" Binding="{Binding MA_NV}" Width="70"/>

                            <DataGridTextColumn Header="Họ và tên" Binding="{Binding HoTen_NV}" Width="*" MinWidth="140"/>

                            <DataGridTextColumn Header="SĐT" Binding="{Binding SoDienThoai_NV}" Width="110"/>

                            <!-- Giới tính - SỬA: Dùng DataTemplate thay vì DataGridTemplate -->
                            <DataGridTemplateColumn Header="Giới tính" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding GioiTinh_NV}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Ngày sinh" Binding="{Binding NgaySinh_NV, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>

                            <DataGridTextColumn Header="Chức vụ" Binding="{Binding ChucVu_NV}" Width="120"/>

                            <!-- Ngày vào làm -->
                            <DataGridTemplateColumn Header="Ngày vào làm" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding NgayVaoLam_NV, StringFormat={}{0:dd/MM/yyyy}}" VerticalAlignment="Center" Foreground="#333"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Email -->
                            <DataGridTemplateColumn Header="Email" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Email}" VerticalAlignment="Center" Foreground="#0066CC" FontStyle="Italic"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Tác vụ - SỬA: Đưa Grid vào trong DataTemplate -->
                            <DataGridTemplateColumn Header="Tác vụ" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="✏️" 
                                                    Command="{Binding DataContext.SuaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    ToolTip="Sửa thông tin" 
                                                    Background="Transparent" BorderThickness="0" Width="28" Height="28"/>
                                            <Button Content="🗑️" 
                                                    Command="{Binding DataContext.XoaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    ToolTip="Xóa nhân viên" 
                                                    Background="Transparent" BorderThickness="0" Width="28" Height="28"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Thống kê tổng số -->
                    <StatusBar DockPanel.Dock="Bottom" Background="#F1F5F9" Margin="-16,10,-16,-16" Padding="10,5">
                        <StatusBarItem Content=""/>
                        <Separator/>
                        <StatusBarItem Content="Tổng nhân viên:"/>
                        <StatusBarItem Content="{Binding TongTien, StringFormat={}{0:N0}}"/>
                        <Separator/>
                        <StatusBarItem Content="Đã chọn:"/>
                        <StatusBarItem Content="{Binding SelectedNhanVien.HoTen_NV}"/>
                    </StatusBar>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>