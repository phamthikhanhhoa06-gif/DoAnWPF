<UserControl x:Class="ql_ks.Views.uc_DichVuAnUongView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ql_ks.Views"
             mc:Ignorable="d"
             d:DesignHeight="750"
             d:DesignWidth="1000">

    <Grid Margin="20" Background="#F5F7FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                Padding="15"
                CornerRadius="8"
                Margin="0,0,0,15"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Phòng -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Mã phòng:"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="#333"
                               Margin="0,0,8,0"/>

                    <TextBox Text="{Binding MaPhong, UpdateSourceTrigger=PropertyChanged}"
                             Width="80"
                             Height="32"
                             Padding="8,3,8,3"
                             VerticalContentAlignment="Center"
                             Background="#F9FAFB"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"/>
                </StackPanel>

                <!-- Tổng tiền -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <TextBlock FontSize="18"
                               FontWeight="Bold"
                               Foreground="OrangeRed"
                               VerticalAlignment="Center">
                        <Run Text="Tổng: "/>
                        <Run Text="{Binding TongTien, StringFormat={}{0:N0}}"/>
                        <Run Text=" ₫"/>
                    </TextBlock>

                    <Button Content="💾 Gửi Đơn"
                            Command="{Binding SaveCommand}"
                            Background="#2ECC71"
                            Foreground="White"
                            Padding="20,8"
                            Margin="15,0,0,0"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="550"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- TRÁI: THỰC ĐƠN -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="THỰC ĐƠN"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#222"
                                   Margin="0,0,0,10"/>

                        <TextBox Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 Padding="10,4"
                                 Background="#F9FAFB"
                                 BorderBrush="#CBD5E1"
                                 BorderThickness="1"
                                 ToolTip="Tìm kiếm theo tên món"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">

                        <ItemsControl ItemsSource="{Binding DanhSachMonAn}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Margin="0,0,0,8"
                                            Padding="10">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Ten_MH}"
                                                           FontWeight="Bold"
                                                           Foreground="#333"
                                                           FontSize="14"
                                                           TextWrapping="Wrap"/>

                                                <TextBlock Foreground="Gray"
                                                           FontSize="13"
                                                           Margin="0,4,0,0">
                                                    <Run Text="{Binding GiaTien, StringFormat={}{0:N0}}"/>
                                                    <Run Text=" ₫"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Content="+"
                                                    Width="32"
                                                    Height="32"
                                                    Command="{Binding DataContext.AddCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#3498DB"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontWeight="Bold"
                                                    Cursor="Hand"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- PHẢI: ĐÃ GỌI -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="DANH SÁCH ĐÃ GỌI"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#222"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding ThongBao}"
                                   Foreground="Red"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding DanhSachDaChon}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="32"
                              Background="White"
                              BorderThickness="0">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên món"
                                                Binding="{Binding Ten_MH}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Đơn giá (₫)"
                                                Binding="{Binding GiaTien, StringFormat={}{0:N0}}"
                                                Width="110"/>

                            <DataGridTextColumn Header="Số lượng"
                                                Binding="{Binding SoLuong}"
                                                Width="70"/>

                            <DataGridTextColumn Header="Thành tiền (₫)"
                                                Binding="{Binding ThanhTien, StringFormat={}{0:N0}}"
                                                Width="120"/>

                            <DataGridTemplateColumn Header="Xóa" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="-"
                                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#E74C3C"
                                                Foreground="White"
                                                Height="28"
                                                Width="28"
                                                BorderThickness="0"
                                                FontWeight="Bold"
                                                Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>