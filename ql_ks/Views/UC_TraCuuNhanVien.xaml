<UserControl x:Class="ql_ks.Views.UC_TraCuuNhanVien"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ql_ks.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <Grid Margin="20" Background="#F3F5FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,16">
            <TextBlock Text="PHẦN MỀM QUẢN LÍ KHÁCH SẠN" FontSize="26" FontWeight="Bold" Foreground="#30324A"/>
            <TextBlock Text="TRA CỨU / QUẢN LÝ NHÂN VIÊN" FontSize="16" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- TRÁI: FILTER + FORM NHẬP (CÓ THANH KÉO) -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
                    <StackPanel>
                        <!-- ====== PHẦN TÌM KIẾM / LỌC ====== -->
                        <TextBlock Text="🔍 Tìm kiếm" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"
                     Height="34" Padding="10,0" VerticalContentAlignment="Center"
                     BorderBrush="#CBD5E1" BorderThickness="1"/>

                        <TextBlock Text="📅 Ngày vào làm (từ - đến)" FontWeight="Bold" Foreground="#374151" Margin="0,14,0,6"/>
                        <DatePicker SelectedDate="{Binding NgayBatDau}" Height="32" Margin="0,0,0,5" BorderBrush="#CBD5E1"/>
                        <DatePicker SelectedDate="{Binding NgayKetThuc}" Height="32" BorderBrush="#CBD5E1"/>

                        <TextBlock Text="🎭 Lọc chức vụ" FontWeight="Bold" Foreground="#374151" Margin="0,14,0,6"/>
                        <ComboBox ItemsSource="{Binding LocChucVuList}"
                      SelectedItem="{Binding LocChucVu}"
                      Height="32" BorderBrush="#CBD5E1"/>

                        <Button Content="🔍 Tìm kiếm" Command="{Binding TimKiemCommand}" 
                    Background="#3498DB" Foreground="White" Height="36" Margin="0,12,0,0" 
                    BorderThickness="0" FontWeight="Bold"/>
                        <Button Content="✖ Làm mới" Command="{Binding LamMoiCommand}" 
                    Background="#95A5A6" Foreground="White" Height="36" Margin="0,8,0,0" 
                    BorderThickness="0"/>

                        <!-- ====== PHẦN NHẬP / SỬA NHÂN VIÊN ====== -->
                        <Border Background="#F1F5F9" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" 
                    Padding="12" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="➕ Thông tin nhân viên" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>

                                <TextBlock Text="Họ và tên *" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SelectedNhanVien.HoTen_NV, UpdateSourceTrigger=PropertyChanged}" 
                             Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#94A3B8"/>

                                <TextBlock Text="Số điện thoại" FontSize="11" Foreground="#64748B" Margin="0,8,0,4"/>
                                <TextBox Text="{Binding SelectedNhanVien.SoDienThoai_NV, UpdateSourceTrigger=PropertyChanged}" 
                             Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#94A3B8"/>

                                <TextBlock Text="Giới tính" FontSize="11" Foreground="#64748B" Margin="0,8,0,4"/>
                                <ComboBox SelectedItem="{Binding SelectedNhanVien.GioiTinh_NV}" Height="32" BorderBrush="#94A3B8">
                                    <ComboBoxItem>Nam</ComboBoxItem>
                                    <ComboBoxItem>Nữ</ComboBoxItem>
                                </ComboBox>

                                <TextBlock Text="Ngày sinh" FontSize="11" Foreground="#64748B" Margin="0,8,0,4"/>
                                <DatePicker SelectedDate="{Binding SelectedNhanVien.NgaySinh_NV}" Height="32" BorderBrush="#94A3B8"/>

                                <TextBlock Text="Chức vụ" FontSize="11" Foreground="#64748B" Margin="0,8,0,4"/>
                                <ComboBox ItemsSource="{Binding LocChucVuList}" 
                              SelectedItem="{Binding SelectedNhanVien.ChucVu_NV}"
                              Height="32" BorderBrush="#94A3B8"/>

                                <TextBlock Text="Địa chỉ" FontSize="11" Foreground="#64748B" Margin="0,8,0,4"/>
                                <TextBox Text="{Binding SelectedNhanVien.DiaChi_NV, UpdateSourceTrigger=PropertyChanged}" 
                             Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#94A3B8"/>
                            </StackPanel>
                        </Border>

                        <!-- Nút Lưu -->
                        <Button Content="💾 LƯU NHÂN VIÊN" Command="{Binding LuuCommand}" 
                    Background="#F59E0B" Foreground="White" Height="38" Margin="0,12,0,0" 
                    BorderThickness="0" FontWeight="Bold" FontSize="14" Cursor="Hand"/>

                        <TextBlock Text="{Binding ThongBao}" Foreground="Red" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- PHẢI: DATA GRID + ACTIONS -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
                <DockPanel>
                    <!-- Thanh công cụ DataGrid - SỬA: Thêm ToolBar -->
                    <ToolBarTray DockPanel.Dock="Top" Background="WhiteSmoke" Margin="0,0,0,10">
                        <ToolBar>
                            <Button Content="➕ Thêm mới" Command="{Binding ThemCommand}" ToolTip="Thêm nhân viên mới" Background="#27AE60" Foreground="White" Padding="8,5" BorderThickness="0"/>
                            <!-- THÊM DÒNG NÀY -->
                            <Button Content="💾 Lưu" Command="{Binding LuuCommand}" 
            Background="#F59E0B" Foreground="White" Padding="8,5" BorderThickness="0" 
            Margin="0,0,5,0" ToolTip="Lưu nhân viên"/>
                            <Button Content="✏️ Sửa" Command="{Binding SuaCommand}" ToolTip="Sửa nhân viên được chọn" Background="#2980B9" Foreground="White" Padding="8,5" BorderThickness="0"/>
                            <Button Content="❌ Xóa" Command="{Binding XoaCommand}" ToolTip="Xóa nhân viên được chọn" Background="#E74C3C" Foreground="White" Padding="8,5" BorderThickness="0"/>
                            <Separator/>
                            <Button Content="📊 Xuất báo cáo" ToolTip="Xuất Excel/PDF báo cáo thống kê" Background="#95A5A6" Foreground="White" Padding="8,5" BorderThickness="0"/>
                        </ToolBar>
                    </ToolBarTray>

                    <DataGrid ItemsSource="{Binding DanhSachHienThi}" 
                              SelectedItem="{Binding SelectedNhanVien, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="36"
                              SelectionMode="Single"
                              BorderThickness="0"
                              Background="White">

                        <DataGrid.Columns>
                            <!-- Checkbox cột đầu tiên - SỬA: Bỏ ElementStyle rối rắm -->
                            <DataGridCheckBoxColumn Header="" Width="40" Binding="{Binding IsChecked, Mode=TwoWay}">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>

                            <DataGridTextColumn Header="Mã NV" Binding="{Binding MA_NV}" Width="70"/>

                            <DataGridTextColumn Header="Họ và tên" Binding="{Binding HoTen_NV}" Width="*" MinWidth="140"/>

                            <DataGridTextColumn Header="SĐT" Binding="{Binding SoDienThoai_NV}" Width="110"/>

                            <!-- Giới tính - SỬA: Dùng DataTemplate thay vì DataGridTemplate -->
                            <DataGridTemplateColumn Header="Giới tính" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding GioiTinh_NV}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Ngày sinh" Binding="{Binding NgaySinh_NV, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>

                            <DataGridTextColumn Header="Chức vụ" Binding="{Binding ChucVu_NV}" Width="120"/>

                            <!-- Ngày vào làm -->
                            <DataGridTemplateColumn Header="Ngày vào làm" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding NgayVaoLam_NV, StringFormat={}{0:dd/MM/yyyy}}" VerticalAlignment="Center" Foreground="#333"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Email -->
                            <DataGridTemplateColumn Header="Email" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Email}" VerticalAlignment="Center" Foreground="#0066CC" FontStyle="Italic"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Tác vụ - SỬA: Đưa Grid vào trong DataTemplate -->
                            <DataGridTemplateColumn Header="Tác vụ" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="✏️" 
                                                    Command="{Binding DataContext.SuaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    ToolTip="Sửa thông tin" 
                                                    Background="Transparent" BorderThickness="0" Width="28" Height="28"/>
                                            <Button Content="🗑️" 
                                                    Command="{Binding DataContext.XoaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    ToolTip="Xóa nhân viên" 
                                                    Background="Transparent" BorderThickness="0" Width="28" Height="28"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Thống kê tổng số -->
                    <StatusBar DockPanel.Dock="Bottom" Background="#F1F5F9" Margin="-16,10,-16,-16" Padding="10,5">
                        <StatusBarItem Content=""/>
                        <Separator/>
                        <StatusBarItem Content="Tổng nhân viên:"/>
                        <StatusBarItem Content="{Binding TongTien, StringFormat={}{0:N0}}"/>
                        <Separator/>
                        <StatusBarItem Content="Đã chọn:"/>
                        <StatusBarItem Content="{Binding SelectedNhanVien.HoTen_NV}"/>
                    </StatusBar>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>