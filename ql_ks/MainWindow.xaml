<Window x:Class="ql_ks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ql_ks"
        xmlns:views="clr-namespace:ql_ks.Views"
        mc:Ignorable="d"
         Title="Phần mềm Quản Lý Khách Sạn"
        Height="800"
        Width="1400"
        Background="#F0F2F5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <Image Source="/Resources/HotelLogo.png"
                       Width="100"
                       HorizontalAlignment="Center"
                       Margin="0,30,0,10"/>

                <TextBlock Text="HOTEL SYSTEM"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- Nút Trang chủ -->
                <Button Content="TRANG CHỦ"
                        Click="BtnTrangChu_Click"
                        Background="Transparent"
                        Foreground="#ECF0F1"
                        BorderThickness="0"
                        FontSize="16"
                        FontWeight="Bold"
                        HorizontalAlignment="Stretch"
                        Padding="20,10"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"/>

                <!-- Nút Dịch vụ ăn uống -->
                <Button Content="DỊCH VỤ ĂN UỐNG"
                        Click="BtnDichVuAnUong_Click"
                        Background="Transparent"
                        Foreground="#BDC3C7"
                        BorderThickness="0"
                        FontSize="15"
                        HorizontalAlignment="Stretch"
                        Padding="20,10"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"/>

                <Button Content="DỊCH VỤ GIẶT ỦI"
                        Background="Transparent"
                        Foreground="#BDC3C7"
                        BorderThickness="0"
                        FontSize="15"
                        HorizontalAlignment="Stretch"
                        Padding="20,10"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"/>

                <Button Content="DỊCH VỤ DI CHUYỂN"
                        Background="Transparent"
                        Foreground="#BDC3C7"
                        BorderThickness="0"
                        FontSize="15"
                        HorizontalAlignment="Stretch"
                        Padding="20,10"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"/>

                <Button Content="TRA CỨU QUẢN LÝ"
                        Background="Transparent"
                        Foreground="#BDC3C7"
                        BorderThickness="0"
                        FontSize="15"
                        HorizontalAlignment="Stretch"
                        Padding="20,10"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"/>

                <Button Content="BÁO CÁO, THỐNG KÊ"
                        Background="Transparent"
                        Foreground="#BDC3C7"
                        BorderThickness="0"
                        FontSize="15"
                        HorizontalAlignment="Stretch"
                        Padding="20,10"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"/>

                <Button Content="THÔNG TIN"
                        Background="Transparent"
                        Foreground="#BDC3C7"
                        BorderThickness="0"
                        FontSize="15"
                        HorizontalAlignment="Stretch"
                        Padding="20,10"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand"/>

                <StackPanel Margin="20" VerticalAlignment="Bottom">
                    <TextBlock Text="Võ Ngọc Phong"
                               FontSize="12"
                               Foreground="#95a5a6"/>
                    <TextBlock Text="Quản lý"
                               FontSize="12"
                               Foreground="#7f8c8d"/>

                    <Button Content="Đăng xuất"
                            Click="BtnLogout_Click"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,20,0,0" Height="43"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- NỘI DUNG CHÍNH -->
        <ContentControl x:Name="MainContent" Grid.Column="1" Margin="30"/>
    </Grid>
</Window>