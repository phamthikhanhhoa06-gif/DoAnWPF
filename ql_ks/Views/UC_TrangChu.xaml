<UserControl x:Class="ql_ks.Views.UC_TrangChu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ql_ks.Views"
             mc:Ignorable="d" 
        d:DesignHeight="800" d:DesignWidth="1400">

    <Grid Background="#F0F2F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>



        <!-- NỘI DUNG PHẢI (giữ nguyên như cũ) -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 1. Thanh Thống Kê -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="-228,10,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalRooms}" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Tổng số" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding EmptyRooms}" FontSize="24" FontWeight="Bold" Foreground="Green"/>
                        <TextBlock Text="Còn trống" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding RentedRooms}" FontSize="24" FontWeight="Bold" Foreground="Orange"/>
                        <TextBlock Text="Đang thuê" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding RepairRooms}" FontSize="24" FontWeight="Bold" Foreground="Red"/>
                        <TextBlock Text="Đang sửa" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Nút Bộ Lọc -->
            <Border Background="White" CornerRadius="10" Padding="10" Margin="-228,103,0,20" Grid.RowSpan="2">
                <StackPanel Orientation="Horizontal">
                    <Button Content="🏠 Tất cả" Command="{Binding FilterAllCommand}" Background="#2C3E50" Foreground="White" Padding="10,5"/>
                    <Button Content="⚪ Trống" Command="{Binding FilterEmptyCommand}" Background="#F1C40F" Foreground="White" Padding="10,5"/>
                    <Button Content="🔵 Thuê" Command="{Binding FilterRentedCommand}" Background="#3498DB" Foreground="White" Padding="10,5"/>
                    <Button Content="🛠 Sửa chữa" Background="#E74C3C" Foreground="White" Padding="10,5"/>
                </StackPanel>
            </Border>

            <!-- 3. Danh Sách Phòng -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="-228,0,0,0">
                <WrapPanel Margin="0,0,0,0">
                    <ItemsControl ItemsSource="{Binding RoomList}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="150" Height="120" 
                                        Background="{Binding ColorBackground}" 
                                        CornerRadius="8" Margin="10" 
                                        Cursor="Hand" BorderBrush="#DDD" 
                                        BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Ma_Phong}" FontSize="24" FontWeight="Bold" Foreground="{Binding ColorText}"/>
                                        <TextBlock Text="{Binding Ten_TP}" FontSize="14" TextAlignment="Center" Foreground="{Binding ColorText}"/>
                                        <TextBlock Text="{Binding TinhTrang}" FontSize="12" Foreground="{Binding ColorText}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>